generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  CONTENT_CREATOR
  ADMIN
}

model User {
  id           String                 @id @default(cuid())
  email        String                 @unique
  passwordHash String
  role         UserRole               @default(CONTENT_CREATOR)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  profile      ContentCreatorProfile?
  courses      Course[]
  assets       Asset[]
}

model ContentCreatorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  photoUrl       String?
  curriculum     String?
  professionalId String?
  organization   String?
  jobTitle       String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String    @id @default(cuid())
  ownerId     String
  title       String
  description String?
  coverUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contents    Content[]

  @@index([ownerId])
}

model Content {
  id          String     @id @default(cuid())
  courseId    String
  title       String
  body        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials   Material[]

  @@index([courseId])
}

model Material {
  id           String   @id @default(cuid())
  contentId    String
  fileUrl      String
  storagePath  String
  fileName     String
  mimeType     String?
  sizeBytes    Int?
  uploadedAt   DateTime @default(now())

  content      Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

enum AssetKind {
  PROFILE_PHOTO
  COURSE_COVER
  OTHER
}

model Asset {
  id          String    @id @default(cuid())
  ownerId     String?
  kind        AssetKind @default(OTHER)
  storagePath String
  fileName    String
  mimeType    String?
  sizeBytes   Int?
  createdAt   DateTime  @default(now())

  owner       User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
}

enum ServiceTimeRange {
  LESS_THAN_1_YEAR
  ONE_TO_THREE_YEARS
  THREE_TO_FIVE_YEARS
  FIVE_TO_TEN_YEARS
  MORE_THAN_TEN_YEARS
}

enum SatisfactionScore {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum ProjectRepresentativeStatus {
  YES
  NO
  NOT_APPLICABLE
}

model ProfileMappingResponse {
  id                         String                      @id @default(cuid())
  fullName                   String
  registrationNumber         String
  department                 String
  currentRole                String
  serviceTimeRange           ServiceTimeRange
  institutionalEmail         String
  phone                      String
  primaryEducation           String
  otherEducation             String?
  techSkill1                 String
  techSkill2                 String
  techSkill3                 String
  softSkill1                 String
  softSkill2                 String
  softSkill3                 String
  satisfaction               SatisfactionScore
  routinePositives           String?
  improvementPoints          String?
  collaborationSuggestions   String?
  representativeStatus       ProjectRepresentativeStatus
  projectFollowupChallenges  String?
  affinityGroups             String
  additionalNotes            String?
  createdAt                  DateTime                    @default(now())
}
